generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---- models ----
model Cinema {
  id          Int      @id @default(autoincrement())
  nome        String
  localizacao String
  salas       Sala[]
  sessoes     Sessao[]
}

model Sala {
  id         Int      @id @default(autoincrement())
  numero     Int
  capacidade Int
  cinema     Cinema   @relation(fields: [cinemaId], references: [id])
  cinemaId   Int
  sessoes    Sessao[]
}

model Genero {
  id     Int     @id @default(autoincrement())
  nome   String  @unique
  filmes Filme[]
}

model Filme {
  id                  Int      @id @default(autoincrement())
  titulo              String
  duracao             Int
  dataLancamento      DateTime
  classificacaoEtaria String
  genero              Genero   @relation(fields: [generoId], references: [id])
  generoId            Int
  sessoes             Sessao[]
}

model Sessao {
  id            Int        @id @default(autoincrement())
  horario       DateTime
  valorIngresso Float
  sala          Sala       @relation(fields: [salaId], references: [id])
  salaId        Int
  filme         Filme      @relation(fields: [filmeId], references: [id])
  filmeId       Int
  cinema        Cinema     @relation(fields: [cinemaId], references: [id])
  cinemaId      Int
  ingressos     Ingresso[]
}

model Ingresso {
  id        Int      @id @default(autoincrement())
  tipo      String   // "Inteira" ou "Meia"
  valorPago Float
  sessao    Sessao   @relation(fields: [sessaoId], references: [id])
  sessaoId  Int
  pedidos   Pedido[] @relation("PedidoToIngresso")
}

model LancheCombo {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String
  preco     Float
  pedidos   Pedido[] @relation("PedidoToLancheCombo")
}

model Pedido {
  id           Int           @id @default(autoincrement())
  cliente      String
  valorTotal   Float
  ingressos    Ingresso[]    @relation("PedidoToIngresso")
  lancheCombos LancheCombo[] @relation("PedidoToLancheCombo")
  dataPedido   DateTime      @default(now())
}

